# ─── InsForge.dev Credenciales ──────────────────────────────────────────────
# Crea tu proyecto en https://insforge.dev, ve a Settings > API y copia:

# URL base de tu proyecto (ej: https://mi-proyecto.insforge.app)
NEXT_PUBLIC_INSFORGE_URL=https://tu-proyecto.insforge.app

# Clave pública anónima (safe to expose in browser)
NEXT_PUBLIC_INSFORGE_KEY=tu-anon-key-aqui

# Clave secreta de servicio — SOLO para server-side (API Routes, nunca en el browser)
INSFORGE_SERVICE_KEY=tu-service-key-aqui

# ─── Google Maps API ─────────────────────────────────────────────────────────
# Consigue tu clave en https://console.cloud.google.com → APIs & Services
# Activa: Maps JavaScript API + Places API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=tu-google-maps-key-aqui

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
